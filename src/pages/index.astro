<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Harrison Roday</title>
		<style>
			body {
				margin: 0;
				padding: 3rem;
				font-family: -apple-system, system-ui, sans-serif;
				background: #fafafa;
				color: #111;
			}
			h1 {
				font-size: 1.25rem;
				font-weight: 400;
				letter-spacing: 0.05em;
				margin: 0 0 1.5rem 0;
			}
			.contact {
				display: flex;
				align-items: center;
				gap: 0.5rem;
				font-size: 0.95rem;
				color: #555;
			}
			.contact a {
				color: #111;
				text-decoration: none;
			}
			.contact a:hover {
				text-decoration: underline;
			}
			.contact svg {
				width: 18px;
				height: 18px;
				flex-shrink: 0;
			}
		</style>
	</head>
	<body>
		<h1>Harrison Roday</h1>
		<p class="contact">
			Please feel free to get in touch
			<a href="mailto:harrison.roday@gmail.com" aria-label="Email">
				<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
					<rect x="2" y="4" width="20" height="16" rx="2" />
					<path d="M22 4L12 13L2 4" />
				</svg>
			</a>
		</p>
	</body>
</html>
